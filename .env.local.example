# Copy this file to .env.local and paste your Supabase project values.
# Find them in your Supabase dashboard: Project Settings -> API.
# The anon key is meant to be public (it ships in the client); Row Level
# Security is what protects the data.
#
# Leave these blank/absent and the app runs local-only (no cloud sync).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
